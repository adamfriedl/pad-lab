# Copy to terraform.tfvars (gitignored) or pass -var / TF_VAR_*.
project_id   = "your-gcp-project-id"
region       = "us-central1"
bq_location  = "US"
# fec_api_key is loaded into Secret Manager by ./setup.sh (not stored in tfvars)
# alert_email  = "you@example.com"
# pipeline_schedule = "0 14 * * *"
# freshness_hours = 24          # rolling window with zero successes
# freshness_grace_minutes = 120 # confirm before paging (daily schedule + runtime)
# max_records  = 10000
# lookback_days = 7

# Cloud Build image trigger (push to main on pipeline paths).
# One-time: connect this repo in Cloud Build console → Triggers (region us-central1).
# pipeline_github_owner  = "adamfriedl"
# pipeline_github_repo   = "pad-lab"
# pipeline_github_branch = "main"

# Optional: project-scoped billing budget (separate from account-wide budget)
# billing_account_id = "012345-678901-ABCDEF"
# monthly_budget_usd = 25
