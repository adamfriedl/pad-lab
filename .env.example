# FEC API key — free at https://api.data.gov/signup/
# DEMO_KEY works but is rate-limited (40 req/hr)
# export is optional (loaders read .env directly); use it if you source .env in shell
export FEC_API_KEY=DEMO_KEY

# GCP project — defaults to: gcloud config get-value project
# export GCP_PROJECT=your-project-id

# BigQuery / multi-region GCS location (Terraform bq_location)
# Prefer BQ_LOCATION; GCP_REGION still accepted for compatibility.
# export BQ_LOCATION=US

# Cloud Run / Artifact Registry region (Terraform region)
# export CLOUD_RUN_REGION=us-central1

# Email for Cloud Monitoring alerts (written into infra/terraform.tfvars by setup.sh)
# export ALERT_EMAIL=you@example.com

# Incremental fetch overlap when using --since-watermark (days)
# export LOOKBACK_DAYS=7

# Optional: project-scoped billing budget (separate from account-wide budget)
# Find ID: gcloud billing accounts list
# export BILLING_ACCOUNT_ID=012345-678901-ABCDEF

# GitHub Pages: set repo Actions variable VITE_DATA_BASE_URL to terraform output viz_data_base_url
